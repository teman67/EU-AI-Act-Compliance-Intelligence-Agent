# Copy this file to .env and fill in your keys

# Required: OpenAI API key (used for LLM + embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Required for web search fallback: Tavily API key
# Free tier available at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: comma-separated list of allowed CORS origins for the API
# Example: http://localhost:3000,http://localhost:8501
CORS_ALLOW_ORIGINS=http://localhost:8501

# Optional: API logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
